{
  "name": "synaptiq",
  "$schema": "../../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "prefix": "app",
  "sourceRoot": "apps/frontend/web/synaptiq/src",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@angular/build:application",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/frontend/web/synaptiq",
        "browser": "apps/frontend/web/synaptiq/src/main.ts",
        "tsConfig": "apps/frontend/web/synaptiq/tsconfig.app.json",
        "inlineStyleLanguage": "scss",
        "assets": [
          {
            "glob": "**/*",
            "input": "apps/frontend/web/synaptiq/public"
          },
          {
            "glob": "**/*",
            "input": "apps/frontend/web/synaptiq/src/app/assets",
            "output": "app/assets"
          }
        ],
        "styles": [
          "node_modules/@foblex/flow/styles/default.scss",
          "apps/frontend/web/synaptiq/src/styles.scss"
        ],
        "server": "apps/frontend/web/synaptiq/src/main.server.ts",
        "ssr": {
          "entry": "apps/frontend/web/synaptiq/src/server.ts"
        },
        "outputMode": "server"
      },
      "configurations": {
        "production": {
          "budgets": [
            {
              "type": "initial",
              "maximumWarning": "1mb",
              "maximumError": "2mb"
            },
            {
              "type": "anyComponentStyle",
              "maximumWarning": "32kb",
              "maximumError": "64kb"
            }
          ],
          "outputHashing": "all"
        },
        "development": {
          "optimization": false,
          "extractLicenses": false,
          "sourceMap": true
        }
      },
      "defaultConfiguration": "production"
    },
    "serve": {
      "continuous": true,
      "executor": "@angular/build:dev-server",
      "configurations": {
        "production": {
          "buildTarget": "synaptiq:build:production"
        },
        "development": {
          "buildTarget": "synaptiq:build:development"
        }
      },
      "defaultConfiguration": "development"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": ["{projectRoot}/test-output/jest/coverage"],
      "options": {
        "jestConfig": "apps/frontend/web/synaptiq/jest.config.cts",
        "tsConfig": "apps/frontend/web/synaptiq/tsconfig.spec.json"
      }
    },
    "serve-static": {
      "continuous": true,
      "executor": "@nx/web:file-server",
      "options": {
        "buildTarget": "synaptiq:build",
        "port": 4200,
        "staticFilePath": "dist/apps/frontend/web/synaptiq/browser",
        "spa": true
      }
    }
  }
}
