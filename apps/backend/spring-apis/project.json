{
  "name": "spring-apis",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/backend/spring-apis/src",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package -DskipTests -f apps/backend/spring-apis/pom.xml"
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn spring-boot:run -f apps/backend/spring-apis/pom.xml -Dspring-boot.run.profiles=dev"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test -f apps/backend/spring-apis/pom.xml"
      }
    }
  }
}
